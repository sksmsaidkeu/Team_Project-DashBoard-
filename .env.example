# Supabase 프로젝트 연결 정보 (Supabase 대시보드 > Project Settings > API 에서 확인)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon(public) key — 프런트엔드(브라우저)에서 사용, 노출되어도 되는 키
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# service_role key — 백엔드(서버) 전용, 절대 프런트엔드/브라우저에 노출 금지
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 원티드(Wanted) Open API — 요청 헤더 wanted-client-id / wanted-client-secret 두 개가 모두 필요(openapi.json 기준)
WANTED_API=YOUR_WANTED_CLIENT_ID
WANTED_SECRET=YOUR_WANTED_CLIENT_SECRET
WANTED_API_BASE_URL=https://openapi.wanted.jobs

# FastAPI 백엔드(backend/) 서버 설정
API_PORT=8000
DEBUG=true
