# 원티드(Wanted) Open API 인증 정보
# 실제 값은 .env 파일에 넣고(.gitignore에 이미 등록되어 커밋되지 않음),
# `supabase secrets set --env-file .env --project-ref cnliejhptnbkwibbjzcx` 로
# Supabase Edge Function의 secret으로 등록해서 사용합니다.
# (브라우저 클라이언트 코드에서는 절대 직접 읽지 않습니다 — supabase/functions/wanted-proxy 참고)
WANTED_CLIENT_ID=
WANTED_CLIENT_SECRET=

# 로컬 Python ETL 스크립트(fetch_wanted_trend.py, fetch_wanted_jobs.py) 전용.
# 위 WANTED_CLIENT_ID/SECRET과 값은 동일하지만, 두 스크립트가 이미 소문자 이름으로
# .env를 직접 파싱하도록 작성되어 있어 이름을 그대로 맞췄다(Edge Function은 대문자 버전 사용).
client_id=
client_secret=

# Supabase 프로젝트 연결 정보. Supabase 대시보드 > Project Settings > API에서 확인.
# 값을 채운 뒤 `python scripts/generate_config.py`를 실행하면 js/config.js에 자동 반영된다.
# anon/public key는 RLS 정책으로 보호되는 것을 전제로 브라우저에 노출되어도 되는 공개 키라
# js/config.js를 통해 클라이언트에 전달되지만, 아래 SERVICE_ROLE_KEY는 절대 그렇게 하지 않는다.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# 로컬 Python ETL 스크립트가 service_role 키로 RLS를 우회해 upsert할 때 사용.
# 이 키는 절대 브라우저(js/config.js)로 전달하지 않는다 — 로컬 1회성 스크립트 실행 전용
# (scripts/generate_config.py는 이 값을 다루지 않는다).
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 채용 뉴스(js/news.js)용 무료 뉴스 API 키. 비워두면 정적 폴백 뉴스로 대체된다.
# 참고: NewsAPI.org/GNews.io 등 무료 플랜은 브라우저(CORS) 직접 호출을 localhost로 제한하거나
# 상업적 이용을 금지하는 경우가 많아, 값을 채워도 프로덕션 도메인에서는 자동 폴백될 수 있다.
NEWS_API_KEY=
