# 원티드(Wanted) OpenAPI 인증 정보 (openapi.json의 ClientIdHeader/ClientSecretHeader 기준)
# 발급/문의: 원티드 API 계약 담당(team-ml@wantedlab.com) 또는 발급받은 콘솔에서 확인
#
# 주의: 이 값은 브라우저(클라이언트 JS)에 절대 노출되면 안 됩니다.
# 이 프로젝트는 빌드 도구가 없는 정적 SPA라 .env를 브라우저 코드에 직접 주입할 방법이 없으므로,
# 원티드 API 호출은 Supabase Edge Function 등 서버 사이드에서만 이 값을 읽어 대신 호출해야 합니다.
# (참고: js/config.js의 SUPABASE_ANON_KEY는 RLS로 보호되는 공개 키라 클라이언트에 둬도 되지만,
#  아래 두 값은 성격이 다른 비밀키이므로 같은 방식으로 다루면 안 됩니다.)

# HTTP 헤더명: wanted-client-id
client_id=

# HTTP 헤더명: wanted-client-secret
client_secret=

# ---------------------------------------------------------------------------
# Supabase 프로젝트 연결 정보. Supabase 대시보드 > Project Settings > API 에서 값을 확인해 채워주세요.
# 값을 채운 뒤 `python scripts/generate_config.py`를 실행하면 js/config.js에 자동 반영됩니다.
# anon/public key는 RLS(Row Level Security) 정책으로 보호되는 것을 전제로 브라우저에
# 노출되어도 되는 공개 키이므로, client_secret과 달리 js/config.js를 통해 클라이언트에 전달됩니다.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# (선택) categories 시드(scripts/seed_categories.py)처럼 RLS를 우회해 관리자 권한으로 써야 하는
# 로컬 1회성 스크립트 전용 키. Supabase 대시보드 > Project Settings > API의 "service_role" 값.
# 절대 브라우저/js/config.js로 전달하지 마세요(scripts/generate_config.py는 이 값을 다루지 않습니다) —
# RLS를 완전히 우회하는 관리자 키라 노출되면 모든 테이블에 무제한 접근이 가능해집니다.
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 채용 뉴스(js/news.js)용 무료 뉴스 API 키. 비워두면 정적 폴백 뉴스로 대체됩니다.
# 참고: NewsAPI.org/GNews.io 등 무료 플랜은 브라우저(CORS) 직접 호출을 localhost로 제한하거나
# 상업적 이용을 금지하는 경우가 많아, 값을 채워도 프로덕션 도메인에서는 자동으로 폴백될 수
# 있습니다 (PRD.md 8장 참고).
NEWS_API_KEY=

# ---------------------------------------------------------------------------
# Tab1(기업) FastAPI 백엔드(backend/app) 주소. js/api-client.js가 이 값으로 백엔드를 호출합니다.
# 로컬 개발 시 uvicorn 기본 포트(8000) 기준. 배포 시 실제 백엔드 배포 주소로 교체하세요.
# (백엔드 자체 설정은 이 파일이 아니라 backend/.env.example을 따로 참고 — 서버 전용 값이라
# 이 프런트엔드용 .env와는 별개로 관리됩니다.)
API_BASE_URL=http://127.0.0.1:8000
