# Supabase 프로젝트 연결 정보 (Supabase 대시보드 > Project Settings > API 에서 확인)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# service_role 키는 RLS(Row Level Security)를 우회한다.
# 이 백엔드는 FastAPI 레벨에서 자체적으로 소유권/권한 검증(user_id, company_profile_id 일치 여부 등)을
# 수행하는 것을 전제로 service_role 키를 사용하므로, 절대 프런트엔드(브라우저)에 노출하지 않는다.
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 프런트엔드(SPA) 개발 서버 주소. 콤마로 여러 origin을 지정할 수 있다. "*"이면 전체 허용(개발용, 운영에서는 지양).
CORS_ORIGINS=*

# 원티드(Wanted) Open API — categories 시드 스크립트(scripts/seed_categories.py) 전용.
# 요청 헤더 wanted-client-id / wanted-client-secret 두 개가 모두 필요(openapi.json 기준).
WANTED_API=YOUR_WANTED_CLIENT_ID
WANTED_SECRET=YOUR_WANTED_CLIENT_SECRET
WANTED_API_BASE_URL=https://openapi.wanted.jobs
